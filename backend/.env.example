# QuickGift Backend Environment Variables
# Copy to .env and fill in your values

# Core
DEBUG=true
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite+aiosqlite:///./quickgift.db

# Paystack
PAYSTACK_LIVE=false
PAYSTACK_TEST_SECRET_KEY=sk_test_xxx
PAYSTACK_TEST_PUBLIC_KEY=pk_test_xxx

# Termii SMS
TERMII_API_KEY=
TERMII_SENDER_ID=QuickGift

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Kwik Delivery
KWIK_EMAIL=
KWIK_PASSWORD=
KWIK_ENV=test

# Commission
GIFT_COMMISSION_PERCENT=10.0
BEAUTY_COMMISSION_PERCENT=10.0
