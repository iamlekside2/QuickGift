{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "testflight": {
      "distribution": "store",
      "channel": "preview",
      "ios": {
        "autoIncrement": true
      }
    },
    "production": {
      "autoIncrement": true
    }
  }
}
